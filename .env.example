# ---- Database ----
# Local dev (docker compose): postgresql://postgres:postgres@localhost:5432/creator_crm
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creator_crm?schema=public"

# ---- Redis (BullMQ) ----
REDIS_URL="redis://localhost:6379"

# ---- Auth.js / NextAuth ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ---- Seeded owner account (dev only) ----
SEED_OWNER_EMAIL="owner@creatorcrm.local"
SEED_OWNER_PASSWORD="ownerpass123"

# ---- Encryption at rest (AES-256-GCM) ----
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
# Credential/proxy fields are EMPTY tonight; this proves the encryption pattern.
ENCRYPTION_KEY="change-me-32-byte-base64-key-aaaaaaaaaaaaaaaa="
